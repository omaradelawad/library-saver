<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<GridPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="380.0" prefWidth="370.0" style="-fx-background-color: transperent; -fx-background-radius: 20; -fx-border-radius: 20;" styleClass="card" stylesheets="@CSS/general.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.librarysaver.librarysaver.CardsController">
    <effect>
        <DropShadow color="#0000001a" offsetX="0" offsetY="4" radius="8" />
    </effect>

    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
    </columnConstraints>

    <rowConstraints>
        <RowConstraints maxHeight="296.0" minHeight="10.0" prefHeight="296.0" vgrow="SOMETIMES" />
        <RowConstraints maxHeight="1.7976931348623157E308" minHeight="10.0" prefHeight="84.0" vgrow="SOMETIMES" />
    </rowConstraints>

    <children>
        <!-- صورة الغلاف مع ترويسة -->
        <VBox spacing="0" GridPane.rowIndex="0">
            <children>
                <!-- منطقة الصورة -->
                <StackPane prefHeight="180.0" style="-fx-background-color: linear-gradient(to bottom, #f0f0f0, #e0e0e0); -fx-background-radius: 20 20 0 0;">
                    <children>
                        <ImageView fitHeight="180.0" fitWidth="371.0" pickOnBounds="true" preserveRatio="false" style="-fx-background-radius: 20 20 0 0;" />
                        <Rectangle arcHeight="20.0" arcWidth="20.0" fill="transparent" height="111.0" stroke="transparent" width="316.0" />
                        <!-- أيقونة افتراضية إذا لم توجد صورة -->
                        <Label style="-fx-font-size: 60px; -fx-opacity: 0.3;" text="📖" />
                    </children>
                </StackPane>

                <!-- معلومات المجموعة -->
                <VBox alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308" prefHeight="117.0" prefWidth="370.0" spacing="8" style="-fx-background-color: #00564d; -fx-padding: 15 15 10 15;">
                    <children>
                        <Label fx:id="titleLabel" alignment="CENTER_RIGHT" prefHeight="41.0" prefWidth="349.0" text="عنوان المجموعه" textAlignment="JUSTIFY" textFill="WHITE">
                            <font>
                                <Font name="Cairo Bold" size="21.0" />
                            </font>
                     <graphic>
                        <Label fx:id="id" disable="true" prefHeight="17.0" prefWidth="106.0" text="Label" textFill="WHITE" />
                     </graphic>
                        </Label>

                        <Label fx:id="descriptionLabel" style="-fx-font-size: 14px;" text="وصف المجموعة هنا يمكن إضافة مختصرة عن المحتوى" textAlignment="RIGHT" textFill="#7f8c8d" wrapText="true">
                            <font>
                                <Font name="Cairo Black" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </VBox>

              <!-- شريط الأزرار السفلي -->
        <HBox alignment="CENTER" prefHeight="115.0" prefWidth="370.0" spacing="10" style="-fx-background-color: #00564d; -fx-background-radius: 0 0 20 20;" GridPane.rowIndex="1">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>

                  <children>
                <!-- زر العرض -->
                <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="viewSectionButton" mnemonicParsing="false" onAction="#seeSection" prefHeight="62.0" prefWidth="71.0" style="-fx-background-color: #2596be; -fx-background-radius: 25; -fx-cursor: hand;" textFill="WHITE">
                            <graphic>
                                <Label style="-fx-font-size: 20px;" text="👁" />
                            </graphic>
                            <font>
                                <Font name="Cairo Regular" size="14.0" />
                            </font>
                            <effect>
                                <DropShadow color="#2596be80" offsetX="0" offsetY="2" radius="4" />
                            </effect>
                        </Button>
                        <Label text="عرض" textFill="#666666">
                            <font>
                        <Font name="Cairo Regular" size="12.0" />
                     </font>
                        </Label>
                    </children>
                </VBox>

                      <!-- زر التعديل -->
                <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="editSectionButton" mnemonicParsing="false" onAction="#editSection" prefHeight="61.0" prefWidth="72.0" style="-fx-background-color: #7a24bf; -fx-background-radius: 25; -fx-cursor: hand;" textFill="WHITE">
                            <graphic>
                                <Label alignment="CENTER" prefWidth="68.0" style="-fx-font-size: 20px;" text="✏" textAlignment="CENTER" />
                            </graphic>
                            <font>
                                <Font name="Cairo Regular" size="14.0" />
                            </font>
                            <effect>
                                <DropShadow color="#7a24bf80" offsetX="0" offsetY="2" radius="4" />
                            </effect>
                        </Button>
                        <Label text="تعديل" textFill="#666666">
                            <font>
                        <Font name="Cairo Regular" size="12.0" />
                     </font>
                        </Label>
                    </children>
                </VBox>

                      <!-- زر الحذف -->
                <VBox alignment="CENTER" spacing="3" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="deleteSectionButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#deleteSection" prefHeight="61.0" prefWidth="61.0" style="-fx-background-color: #e74c3c; -fx-background-radius: 25; -fx-cursor: hand;" textFill="WHITE">
                            <graphic>
                                <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="48.0" prefWidth="65.0" style="-fx-font-size: 20px;" text="🗑" />
                            </graphic>
                            <font>
                                <Font name="Cairo Regular" size="14.0" />
                            </font>
                            <effect>
                                <DropShadow color="#e74c3c80" offsetX="0" offsetY="2" radius="4" />
                            </effect>
                        </Button>
                        <Label text="حذف" textFill="#666666">
                            <font>
                        <Font name="Cairo Regular" size="12.0" />
                     </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</GridPane>
